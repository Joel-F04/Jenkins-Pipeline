pipeline{
    agent any

    stages{
        stage('Build'){
            steps{
                echo 'Using build tool Maven to automatically compile and package the code'
            }
        }

        stage('Unit and Integration Tests'){
            steps{
                echo 'Using Selenium to conduct Unit and Integration tests'
            }
        }

        stage('Code Analysis'){
            steps{
                echo 'Using SonarQube to conduct code analysis, allowing for the identification of issues early'
            }
        }

        stage('Security Scan'){
            steps{
                echo 'SonarQube also performs security scans to identify vulnerabilities in the codebase'
            }
        }

        stage('Deploying to Staging'){
            steps{
                echo 'Deploying application to staging server AWS EC2 Instance'
            }
        }

        stage('Integration Testing on Staging'){
            steps{
                echo 'Running integration tests in staging environment to ensure correct function'
            }
        }

        stage('Deploy to Production Test for auto build'){
            steps{
                echo 'Deploying application to production server AWS EC2 Instance'
            }
        }
    }
}
